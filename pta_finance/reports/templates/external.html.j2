<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ report.organization }} — Financial Summary FY{{ report.fiscal_year }}</title>
  <style>
    body { font-family: system-ui, Arial, sans-serif; margin: 2rem; color: #222; }
    h1, h2 { color: #2a4d69; }
    table { border-collapse: collapse; width: 100%; margin: 0.5rem 0 1.5rem; }
    th, td { border: 1px solid #ccc; padding: 4px 8px; text-align: left; font-size: 0.9rem; }
    th { background: #eef3f8; }
    td.num { text-align: right; font-variant-numeric: tabular-nums; }
    img.chart { max-width: 100%; height: auto; border: 1px solid #ddd; }
    .note { color: #666; font-size: 0.85rem; }
  </style>
</head>
<body>
  <h1>{{ report.organization }}</h1>
  <p>{{ report.school_name }} — Public financial summary for Fiscal Year {{ report.fiscal_year }}</p>
  <p class="note">This public summary reports aggregate figures only; it contains no
     vendor, payee, or member details.</p>

  <h2 data-section="totals">Totals</h2>
  <table data-section="totals-table">
    <tr><th>Income</th><td class="num">${{ report.totals.income }}</td></tr>
    <tr><th>Expense</th><td class="num">${{ report.totals.expense }}</td></tr>
    <tr><th>Net</th><td class="num">${{ report.totals.net }}</td></tr>
  </table>

  <h2 data-section="fundraising">Fundraising progress</h2>
  <p>Raised <strong>${{ report.fundraising.raised }}</strong> of
     target <strong>${{ report.fundraising.target }}</strong>
     {% if report.fundraising.pct is not none %}({{ report.fundraising.pct }}%){% endif %}.</p>

  <h2 data-section="budget-headline">Budget headline (FY{{ report.budget_headline.fiscal_year }})</h2>
  <table data-section="budget-headline-table">
    <tr><th>Total budgeted</th><td class="num">${{ report.budget_headline.total_budgeted }}</td></tr>
    <tr><th>Total spent</th><td class="num">${{ report.budget_headline.total_spent }}</td></tr>
    <tr><th>Remaining</th><td class="num">${{ report.budget_headline.remaining }}</td></tr>
  </table>

  <h2 data-section="by-grade">Allocation by grade</h2>
  <img class="chart" src="{{ grade_chart_uri }}" alt="Net allocation by grade">
  <table data-section="by-grade-table">
    <thead><tr><th>Grade</th><th>Income</th><th>Expense</th><th>Net</th></tr></thead>
    <tbody>
    {% for g in report.by_grade %}
      <tr>
        <td>{{ g.grade }}</td>
        <td class="num">${{ g.income }}</td>
        <td class="num">${{ g.expense }}</td>
        <td class="num">${{ g.net }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</body>
</html>
